---
import { Icon } from "astro-icon/components";
import { getRuntimeState } from "@/server/runtime-state";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.astro";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
const { navBarConfig: runtimeNavBarConfig, siteConfig: runtimeSiteConfig } =
	await getRuntimeState();

let links: NavBarLink[] = (
	runtimeNavBarConfig?.links || navBarConfig.links
).map((item: NavBarLink | LinkPreset): NavBarLink => {
	if (typeof item === "number") {
		return LinkPresets[item];
	}
	return item;
});
---
<div id="navbar" class="z-50 onload-animation">
	<div class="absolute left-0 right-0 -top-8 h-8 bg-[var(--card-bg)] transition"></div>
	<div class:list={[
		className,
		"card-base !overflow-visible mx-auto flex h-[4.5rem] max-w-[var(--page-width)] items-center justify-between !rounded-t-none px-4",
	]}>
		<a href={url("/")} class="btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95">
			<div class="flex flex-row items-center text-md text-[var(--primary)]">
				<Icon name="material-symbols:home-outline-rounded" class="mb-1 mr-2 text-[1.75rem]" />
				{runtimeSiteConfig?.title || siteConfig.title}
			</div>
		</a>
		<div class="hidden md:flex">
			{links.map((l) => {
				const href = l.external ? l.url : url(l.url);
				return <a aria-label={l.name} href={href} target={l.external ? "_blank" : null}
						  data-no-swup={(!l.external && href.includes("/admin/")) || undefined}
						  class="btn-plain scale-animation rounded-lg h-11 px-5 font-bold active:scale-95"
				>
					<div class="flex items-center">
						{l.icon && <Icon name={l.icon} class="mr-2 text-[1.05rem]"></Icon>}
						{l.name}
						{l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="ml-1 -translate-y-[1px] text-[0.875rem] text-black/[0.2] transition dark:text-white/[0.2]"></Icon>}
					</div>
				</a>;
			})}
		</div>
		<div class="flex">
			<Search client:only="svelte"></Search>
			{!(runtimeSiteConfig?.themeColor.fixed ?? siteConfig.themeColor.fixed) && (
				<button aria-label="Display Settings" class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90" id="display-settings-switch">
					<Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
				</button>
			)}
			<LightDarkSwitch></LightDarkSwitch>
			<a
				aria-label="Admin"
				href={url("/admin/")}
				data-no-swup
				title="进入后台"
				class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90"
			>
				<Icon name="material-symbols:admin-panel-settings-outline-rounded" class="text-[1.25rem]"></Icon>
			</a>
			<button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation h-11 w-11 rounded-lg active:scale-90 md:!hidden" id="nav-menu-switch">
				<Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
			</button>
		</div>
		<NavMenuPanel links={links}></NavMenuPanel>
		<DisplaySettings client:only="svelte"></DisplaySettings>
	</div>
</div>

<script>
	function loadButtonScript() {
		const settingBtn = document.getElementById("display-settings-switch");
		if (settingBtn) {
			settingBtn.onclick = function () {
				const settingPanel = document.getElementById("display-setting");
				if (settingPanel) {
					settingPanel.classList.toggle("float-panel-closed");
				}
			};
		}

		const menuBtn = document.getElementById("nav-menu-switch");
		if (menuBtn) {
			menuBtn.onclick = function () {
				const menuPanel = document.getElementById("nav-menu-panel");
				if (menuPanel) {
					menuPanel.classList.toggle("float-panel-closed");
				}
			};
		}
	}

	loadButtonScript();
</script>

{import.meta.env.PROD && <script is:inline define:vars={{scriptUrl: url('/pagefind/pagefind.js')}}>
	async function loadPagefind() {
		try {
			const response = await fetch(scriptUrl, { method: "HEAD" });
			if (!response.ok) {
				throw new Error(`Pagefind script not found: ${response.status}`);
			}

			const pagefind = await import(scriptUrl);

			await pagefind.options({
				excerptLength: 20,
			});

			window.pagefind = pagefind;

			document.dispatchEvent(new CustomEvent("pagefindready"));
			console.log("Pagefind loaded and initialized successfully, event dispatched.");
		} catch (error) {
			console.error("Failed to load Pagefind:", error);
			window.pagefind = {
				search: () => Promise.resolve({ results: [] }),
				options: () => Promise.resolve(),
			};
			document.dispatchEvent(new CustomEvent("pagefindloaderror"));
			console.log("Pagefind load error, event dispatched.");
		}
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", loadPagefind);
	} else {
		loadPagefind();
	}
</script>}
