---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import { getRuntimeState } from "@/server/runtime-state";
import ImageWrapper from "../misc/ImageWrapper.astro";

const { profileConfig: runtimeProfileConfig } = await getRuntimeState();
const config = runtimeProfileConfig || profileConfig;
const avatarInitials =
	config.name
		.split(/\s+/)
		.filter(Boolean)
		.slice(0, 2)
		.map((item) => item[0]?.toUpperCase() || "")
		.join("") || "CX";
---
<div class="card-base p-3">
    <a aria-label="Go to About Page" href={url('/about/')}
       class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
       max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95">
        <div class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
        w-full h-full z-50 flex items-center justify-center">
            <Icon name="fa6-regular:address-card"
                  class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl">
            </Icon>
        </div>
        {config.avatar ? (
            <ImageWrapper src={config.avatar} alt="Profile Image of the Author" class="mx-auto lg:w-full h-full lg:mt-0 "></ImageWrapper>
        ) : (
            <div class="mx-auto lg:w-full aspect-square lg:mt-0 bg-gradient-to-br from-[oklch(0.78_0.12_var(--hue))] via-[oklch(0.58_0.10_var(--hue))] to-[oklch(0.32_0.05_var(--hue))] flex items-center justify-center">
                <span class="font-black text-4xl tracking-[0.35em] text-white/85 ml-[0.35em]">
                    {avatarInitials}
                </span>
            </div>
        )}
    </a>
    <div class="px-2">
        <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition">{config.name}</div>
        <div class="h-1 w-5 bg-[var(--primary)] mx-auto rounded-full mb-2 transition"></div>
        <div class="text-center text-neutral-400 mb-2.5 transition">{config.bio}</div>
        <div class="flex flex-wrap gap-2 justify-center mb-1">
            {config.links.length > 1 && config.links.map(item =>
                    <a rel="me" aria-label={item.name || item.url} title={item.name || item.url} href={item.url} target="_blank" class="btn-regular rounded-lg h-10 w-10 active:scale-90">
                        <Icon name={item.icon} class="text-[1.5rem]"></Icon>
                    </a>
            )}
            {config.links.length == 1 && <a rel="me" aria-label={config.links[0].name || config.links[0].url} title={config.links[0].name || config.links[0].url} href={config.links[0].url} target="_blank"
                                            class:list={[
                                                "btn-regular rounded-lg h-10 font-bold active:scale-95",
                                                config.links[0].name ? "gap-2 px-3" : "w-10 justify-center",
                                            ]}>
                <Icon name={config.links[0].icon} class="text-[1.5rem]"></Icon>
                {config.links[0].name && config.links[0].name}
            </a>}
        </div>
    </div>
</div>
