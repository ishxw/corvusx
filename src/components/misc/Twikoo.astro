---
interface Props {
	config: {
		enable: boolean;
		envId: string;
	};
	path?: string;
	class?: string;
}

const { path, class: className, config } = Astro.props;
const { enable } = config;
---

{enable && (
    <>
        <div id="tcomment" class={className} data-twikoo-path={path}></div>
        <style is:global>
            /* Suppress Twikoo's large black avatar flicker during initial load */
            #tcomment .tk-submit .tk-avatar.tk-has-avatar {
                opacity: 0;
            }
            #tcomment .tk-comments-container .tk-avatar {
                opacity: 0;
            }
            /* Show once loaded */
            #tcomment.twikoo-loaded .tk-avatar {
                opacity: 1;
                transition: opacity 0.3s ease;
            }
        </style>
    </>
)}
