---
import AdminLayout from "@/layouts/AdminLayout.astro";

if (!Astro.locals.adminUser) {
	return Astro.redirect("/admin/login/");
}

const success = Astro.url.searchParams.get("success");
const error = Astro.url.searchParams.get("error");
---

<AdminLayout
	title="安全中心"
	description="更新后台管理员密码。建议上线后尽快替换默认凭据，并定期更换以确保安全。"
	success={success ? "密码已成功重置，新密码已生效。" : null}
	error={
		error === "mismatch"
			? "当前密码验证失败，请重试。"
			: error === "short"
				? "新密码强度不足（至少 8 位）。"
				: error
					? "重置失败，系统遇到预期外错误。"
					: null
	}
>
	<div class="grid gap-8 lg:grid-cols-[1fr_380px]">
		<!-- Form Section -->
		<form method="post" action="/admin/api/password/" class="card-base p-8 md:p-10" data-admin-card>
			<div class="mb-10">
				<h2 class="text-2xl font-black tracking-tight text-black/90 dark:text-white/95">重置管理员密码</h2>
				<p class="mt-2 text-sm text-black/40 dark:text-white/40">修改后无需重新登录，但新密码会立即应用于下次身份验证。</p>
			</div>

			<div class="grid gap-8 sm:grid-cols-2">
				<label class="block">
					<div class="admin-label">当前密码</div>
					<input
						name="currentPassword"
						type="password"
						required
						placeholder="验证身份"
						autocomplete="current-password"
					/>
				</label>
				<div></div>
				<label class="block">
					<div class="admin-label">新密码</div>
					<input
						name="nextPassword"
						type="password"
						required
						minlength="8"
						placeholder="输入新密码"
						autocomplete="new-password"
					/>
					<div class="mt-3 text-[10px] font-medium text-black/30 dark:text-white/20 italic">建议包含字母、数字与特殊符号。</div>
				</label>
			</div>

			<div class="mt-12 flex flex-wrap gap-3 border-t border-black/5 pt-8 dark:border-white/5">
				<button type="submit" class="btn-regular rounded-2xl px-8 py-3.5 font-black shadow-lg">
					更新安全凭据
				</button>
				<a href="/admin/" data-admin-plain-btn class="btn-plain rounded-2xl px-6 py-3.5 font-bold text-sm">
					取消并返回
				</a>
			</div>
		</form>

		<!-- Info Sidebar -->
		<aside class="space-y-6">
			<section class="card-base p-8" data-admin-card>
				<div class="mb-6 flex items-center gap-3 text-sky-500">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					<h3 class="text-lg font-black tracking-tight text-black/90 dark:text-white/95">安全建议</h3>
				</div>
				
				<div class="space-y-4">
					{[
						{ title: "替换默认凭据", desc: "默认密码 admin 极易被暴力破解，强烈建议在公共网络部署前进行更改。" },
						{ title: "保护 data 目录", desc: "所有账号与安全哈希均存储在 data 目录，请确保该目录在部署环境中具有持久化。" },
						{ title: "环境验证", desc: "建议在修改后手动通过登录页面验证新密码，以防输入错误导致无法进入后台。" }
					].map(tip => (
						<div class="rounded-2xl bg-black/[0.03] p-5 dark:bg-white/[0.03]">
							<div class="text-[10px] font-black uppercase tracking-widest text-black/40 dark:text-white/40">{tip.title}</div>
							<p class="mt-2 text-xs leading-relaxed text-black/50 dark:text-white/60">{tip.desc}</p>
						</div>
					))}
				</div>
			</section>
		</aside>
	</div>
</AdminLayout>
