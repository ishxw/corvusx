---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listAdminActivities } from "@/server/admin-activity";
import { getAdminPostStatus } from "@/server/admin-post-status";
import { resolveAdminPreviewUrl } from "@/server/admin-preview";
import { listAdminPosts } from "@/server/post-store";
import { getSiteSettings } from "@/server/site-store";

if (!Astro.locals.adminUser) {
	return Astro.redirect("/admin/login/");
}

const posts = await listAdminPosts();
const activities = await listAdminActivities();
const settings = await getSiteSettings();
const successCode = Astro.url.searchParams.get("success");
const errorCode = Astro.url.searchParams.get("error");
const status = Astro.url.searchParams.get("status") || "all";
const sort = Astro.url.searchParams.get("sort") || "published-desc";
const queryInput = Astro.url.searchParams.get("q") || "";
const query = queryInput.trim().toLowerCase();
const count = Number(Astro.url.searchParams.get("count") || "0");

const avatarPreview = await resolveAdminPreviewUrl(settings.profileAvatar);
const bannerPreview = await resolveAdminPreviewUrl(settings.bannerSrc);

const postsWithStatus = posts.map((post) => ({
	...post,
	statusInfo: getAdminPostStatus(post),
}));

const filteredPosts = postsWithStatus.filter((post) => {
	if (status === "draft" && post.statusInfo.status !== "draft") return false;
	if (status === "published" && post.statusInfo.status !== "published")
		return false;
	if (status === "scheduled" && post.statusInfo.status !== "scheduled")
		return false;
	if (query) {
		const haystack =
			`${post.title} ${post.slug} ${post.category} ${post.tags.join(" ")}`.toLowerCase();
		if (!haystack.includes(query)) return false;
	}
	return true;
});

filteredPosts.sort((a, b) => {
	if (sort === "published-asc") return a.published.localeCompare(b.published);
	if (sort === "title-asc") return a.title.localeCompare(b.title, "zh-CN");
	if (sort === "title-desc") return b.title.localeCompare(a.title, "zh-CN");
	if (sort === "status") {
		const weight = { scheduled: 0, draft: 1, published: 2 } as const;
		return weight[a.statusInfo.status] - weight[b.statusInfo.status];
	}
	return b.published.localeCompare(a.published);
});

const successMessage =
	successCode === "published"
		? `已批量发布 ${count} 篇文章。`
		: successCode === "drafted"
			? `已批量转为草稿 ${count} 篇文章。`
			: successCode === "deleted"
				? `已批量删除 ${count} 篇文章。`
				: successCode === "categorized"
					? `已批量更新 ${count} 篇文章的分类。`
					: successCode === "tagged"
						? `已批量更新 ${count} 篇文章的标签。`
						: successCode === "dated"
							? `已批量更新 ${count} 篇文章的发布日期。`
							: successCode === "scheduled"
								? `已批量更新 ${count} 篇文章的定时发布时间。`
								: successCode
									? "操作已完成。"
									: null;

const errorMessage =
	errorCode === "no-selection"
		? "请先选择至少一篇文章。"
		: errorCode === "invalid-action"
			? "批量操作无效，请重试。"
			: errorCode === "batch-failed"
				? "批量处理过程中遇到错误，请检查内容是否有效。"
				: errorCode
					? "操作没有完成，请稍后重试。"
					: null;

const draftCount = postsWithStatus.filter(
	(post) => post.statusInfo.status === "draft",
).length;
const scheduledCount = postsWithStatus.filter(
	(post) => post.statusInfo.status === "scheduled",
).length;
const publishedCount = postsWithStatus.filter(
	(post) => post.statusInfo.status === "published",
).length;
const aboutPreview = settings.aboutMarkdown
	.replace(/^#+\s+/gm, "")
	.replace(/\[(.*?)\]\((.*?)\)/g, "$1")
	.replace(/\*\*(.*?)\*\*/g, "$1")
	.replace(/\n+/g, " ")
	.trim()
	.slice(0, 150);

// Resolve images for all posts
for (const post of filteredPosts) {
	if (post.image) {
		const resolved = await resolveAdminPreviewUrl(post.image);
		if (resolved.isResolvable) {
			(post as any).resolvedImage = resolved.value;
		}
	}
}
---

<AdminLayout
	title="控制台概览"
	description="在这里统一管理文章、站点设置、媒体素材和后台活动。文章仍然会保存到仓库里的 Markdown 文件，但写作和配置现在都可以直接在后台完成。"
	success={successMessage}
	error={errorMessage}
	backHref="/"
	backLabel="查看前台"
>
	<!-- Quick Navigation -->
	<div class="mb-10 flex flex-wrap gap-3">
		<a href="/admin/posts/new/" class="btn-regular group flex items-center gap-2 rounded-2xl px-6 py-3.5 font-bold">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-hover:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
			新建文章
		</a>
		<a href="/admin/settings/" data-admin-plain-btn class="btn-plain rounded-2xl px-5 py-3.5 font-semibold">站点设置</a>
		<a href="/admin/media/" data-admin-plain-btn class="btn-plain rounded-2xl px-5 py-3.5 font-semibold">媒体管理</a>
		<div class="h-10 w-px bg-black/5 dark:bg-white/5 mx-1 hidden sm:block"></div>
		<a href="/admin/password/" data-admin-plain-btn class="btn-plain rounded-2xl px-5 py-3.5 font-semibold">修改密码</a>
		<form method="post" action="/admin/api/logout/" class="inline">
			<button type="submit" data-admin-plain-btn class="btn-plain rounded-2xl px-5 py-3.5 font-semibold text-rose-500/80 hover:text-rose-500">退出登录</button>
		</form>
	</div>

	<!-- Statistics -->
	<div class="mb-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
		{[
			{ label: "文章总数", value: posts.length, icon: "M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z", color: "text-sky-500", bg: "bg-sky-500/5" },
			{ label: "已发布", value: publishedCount, icon: "M22 11.08V12a10 10 0 1 1-5.93-9.14", color: "text-emerald-500", bg: "bg-emerald-500/5" },
			{ label: "草稿", value: draftCount, icon: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7", color: "text-amber-500", bg: "bg-amber-500/5" },
			{ label: "定时发布", value: scheduledCount, icon: "M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z", color: "text-indigo-500", bg: "bg-indigo-500/5" },
		].map(stat => (
			<div data-admin-card class={`card-base group relative flex items-center gap-6 p-7 transition-all hover:scale-[1.03] ${stat.bg}`}>
				<div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-[1.5rem] bg-white shadow-sm dark:bg-white/5 ${stat.color}`}>
					<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d={stat.icon}/></svg>
				</div>
				<div>
					<div class="text-[10px] font-black uppercase tracking-[0.2em] text-black/30 dark:text-white/30">{stat.label}</div>
					<div class="mt-1 text-4xl font-black text-black/90 dark:text-white/95">{stat.value}</div>
				</div>
			</div>
		))}
	</div>

	<div class="grid gap-10 lg:grid-cols-[1fr_360px] xl:grid-cols-[1fr_400px]">
		<!-- Main Content: Article Management -->
		<div class="space-y-10">
			<section data-admin-card class="card-base p-8 md:p-10">
				<div class="mb-10 flex items-center justify-between">
					<div>
						<h2 class="text-3xl font-black tracking-tight text-black/90 dark:text-white/95">文章管理</h2>
						<p class="mt-2 text-sm text-black/40 dark:text-white/40">支持多维搜索、状态筛选与高效批量操作。</p>
					</div>
				</div>

				<!-- Filters -->
				<form method="get" action="/admin/" class="mb-10 flex flex-col gap-6 xl:flex-row xl:items-end">
					<div class="flex-1">
						<div class="admin-label">全文搜索</div>
						<div class="relative group">
							<svg xmlns="http://www.w3.org/2000/svg" class="absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-black/20 transition-colors group-focus-within:text-[var(--primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
							<input
								name="q"
								value={queryInput}
								placeholder="搜索标题、路径、分类或标签..."
								class="w-full !pl-12"
							/>
						</div>
					</div>
					<div class="grid grid-cols-2 gap-4 xl:w-[20rem]">
						<div>
							<div class="admin-label">发布状态</div>
							<select name="status" class="w-full">
								<option value="all" selected={status === "all"}>全部</option>
								<option value="published" selected={status === "published"}>已发布</option>
								<option value="scheduled" selected={status === "scheduled"}>定时发布</option>
								<option value="draft" selected={status === "draft"}>草稿</option>
							</select>
						</div>
						<div>
							<div class="admin-label">列表排序</div>
							<select name="sort" class="w-full">
								<option value="published-desc" selected={sort === "published-desc"}>最新发布优先</option>
								<option value="published-asc" selected={sort === "published-asc"}>最早发布优先</option>
								<option value="status" selected={sort === "status"}>按状态分组</option>
								<option value="title-asc" selected={sort === "title-asc"}>标题 A-Z</option>
								<option value="title-desc" selected={sort === "title-desc"}>标题 Z-A</option>
							</select>
						</div>
					</div>
					<div class="flex gap-3">
						<button type="submit" class="btn-regular rounded-2xl px-8 py-3.5 font-black shadow-lg">搜索</button>
						<a href="/admin/" data-admin-plain-btn class="btn-plain flex h-[52px] items-center justify-center rounded-2xl px-6 font-bold text-sm">重置</a>
					</div>
				</form>

				<!-- Table & Batch Actions -->
				<form method="post" action="/admin/api/posts/batch/" class="space-y-8" data-admin-batch-form>
					<!-- Action Hidden Fields -->
					<input type="hidden" name="action" value="" data-batch-action-field />
					<input type="hidden" name="status" value={status} />
					<input type="hidden" name="sort" value={sort} />
					<input type="hidden" name="q" value={queryInput} />

					<!-- Batch Action Bar -->
					<div class="rounded-[2rem] border border-black/5 bg-black/[0.02] p-8 dark:border-white/5 dark:bg-white/[0.02]">
						<div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
							<div class="max-w-xs">
								<div class="text-lg font-black tracking-tight text-black/80 dark:text-white/80">
									批量操作 <span class="mx-2 inline-flex h-6 w-6 items-center justify-center rounded-full bg-[var(--primary)] text-[10px] text-white" data-selection-count>0</span>
								</div>
								<p class="mt-1 text-[10px] font-bold uppercase tracking-widest text-black/30 dark:text-white/30">勾选下方列表项以开始</p>
							</div>
							<div class="flex flex-wrap gap-2.5">
								<button type="submit" data-batch-submit="publish" data-admin-regular-btn data-batch-action class="btn-regular rounded-xl px-5 py-2.5 text-[10px] font-black uppercase tracking-widest disabled:opacity-30" disabled>立即发布</button>
								<button type="submit" data-batch-submit="draft" data-admin-plain-btn data-batch-action class="btn-plain rounded-xl px-5 py-2.5 text-[10px] font-black uppercase tracking-widest disabled:opacity-30" disabled>转为草稿</button>
								<button type="submit" data-batch-submit="delete" data-batch-action data-confirm="确认永久删除已选中的 {count} 篇文章吗？" class="rounded-xl bg-rose-500 px-5 py-2.5 text-[10px] font-black uppercase tracking-widest text-white transition-all hover:bg-rose-600 disabled:opacity-30" disabled>彻底删除</button>
							</div>
						</div>

						<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
							<div class="space-y-2">
								<div class="admin-label !mb-0 !text-[10px] uppercase tracking-widest text-black/40">批量修改分类</div>
								<input name="category" placeholder="输入新分类" class="!py-3 !text-sm" />
							</div>
							<div class="space-y-2">
								<div class="admin-label !mb-0 !text-[10px] uppercase tracking-widest text-black/40">批量添加标签</div>
								<input name="tags" placeholder="标签，逗号分隔" class="!py-3 !text-sm" />
							</div>
							<div class="space-y-2">
								<div class="admin-label !mb-0 !text-[10px] uppercase tracking-widest text-black/40">修改发布日期</div>
								<input name="published" type="date" class="!py-3 !text-sm" />
							</div>
							<div class="space-y-2">
								<div class="admin-label !mb-0 !text-[10px] uppercase tracking-widest text-black/40">修改计划发布</div>
								<input name="publishAt" type="datetime-local" class="!py-3 !text-sm" />
							</div>
						</div>

						<div class="mt-8 flex flex-wrap gap-2 border-t border-black/5 pt-6 dark:border-white/5">
							{["category", "tags", "published-date", "publish-at"].map(action => (
								<button type="submit" data-batch-submit={`set-${action}`} data-admin-plain-btn data-batch-action class="btn-plain rounded-lg px-4 py-2 text-[10px] font-black uppercase tracking-widest disabled:opacity-30" disabled>
									更新{action === "category" ? "分类" : action === "tags" ? "标签" : action === "published-date" ? "日期" : "定时"}
								</button>
							))}
						</div>
					</div>

					<!-- Article List Table -->
					<div class="overflow-hidden rounded-[2rem] border border-black/5 dark:border-white/5">
						<div class="overflow-x-auto">
							<table class="w-full border-collapse text-left">
								<thead>
									<tr class="bg-black/[0.03] text-[10px] font-black uppercase tracking-[0.2em] text-black/30 dark:bg-white/[0.03] dark:text-white/30">
										<th class="w-16 px-6 py-5 text-center">
											<input type="checkbox" data-select-all class="h-5 w-5 rounded-lg border-black/10 accent-[var(--primary)]" />
										</th>
										<th class="min-w-[300px] px-6 py-5">内容摘要</th>
										<th class="w-32 px-6 py-5">状态</th>
										<th class="w-48 px-6 py-5">发布时间轴</th>
										<th class="w-32 px-6 py-5 text-right">操作</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-black/5 dark:divide-white/5">
									{filteredPosts.length > 0 ? filteredPosts.map((post) => (
										<tr class="group transition-colors hover:bg-black/[0.01] dark:hover:bg-white/[0.01]">
											<td class="px-6 py-7 text-center">
												<input type="checkbox" name="slug" value={post.slug} data-post-checkbox class="h-5 w-5 rounded-lg border-black/10 accent-[var(--primary)]" />
											</td>
											<td class="px-6 py-7">
												<div class="flex items-start gap-4">
													{(post as any).resolvedImage && (
														<img src={(post as any).resolvedImage} class="hidden h-12 w-12 shrink-0 rounded-xl object-cover sm:block" />
													)}
													<div class="min-w-0">
														<div class="truncate text-base font-bold text-black/90 dark:text-white/95" title={post.title}>{post.title}</div>
														<div class="mt-1 flex items-center gap-2">
															<code class="text-[10px] font-bold text-black/30 dark:text-white/30">/{post.slug}</code>
														</div>
														<div class="mt-4 flex flex-wrap gap-1.5">
															{post.category && <span class="rounded-lg bg-[var(--primary)]/10 px-2 py-0.5 text-[9px] font-black uppercase tracking-wider text-[var(--primary)] whitespace-nowrap">{post.category}</span>}
															{post.tags.slice(0, 4).map((tag) => (
																<span class="rounded-lg bg-black/[0.04] px-2 py-0.5 text-[9px] font-bold text-black/40 dark:bg-white/[0.04] dark:text-white/40 whitespace-nowrap">#{tag}</span>
															))}
														</div>
													</div>
												</div>
											</td>
											<td class="px-6 py-7">
												<div class="flex flex-col">
													<span class:list={["inline-flex w-fit whitespace-nowrap rounded-full px-2.5 py-0.5 text-[9px] font-black uppercase tracking-wider", post.statusInfo.badgeClass]}>
														{post.statusInfo.label}
													</span>
												</div>
											</td>
											<td class="px-6 py-7">
												<div class="space-y-2">
													<div class="flex items-center gap-2 text-xs font-bold text-black/60 dark:text-white/60 whitespace-nowrap">
														<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
														{post.published}
													</div>
													{post.publishAt && (
														<div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-widest text-[var(--primary)] whitespace-nowrap">
															<svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
															计划：{post.publishAt.slice(0, 16).replace("T", " ")}
														</div>
													)}
												</div>
											</td>
											<td class="px-6 py-7 text-right">
												<div class="flex items-center justify-end gap-5 whitespace-nowrap">
													<a href={`/admin/posts/${post.slug}/`} class="text-xs font-black uppercase tracking-widest text-[var(--primary)] hover:underline">编辑</a>
													<a href={`/posts/${post.slug}/?preview=1`} target="_blank" class="text-xs font-black uppercase tracking-widest text-black/30 hover:text-black/90 dark:text-white/30 dark:hover:text-white/95">预览</a>
												</div>
											</td>
										</tr>
									)) : (
										<tr>
											<td colspan="5" class="px-8 py-32 text-center">
												<div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-black/[0.02] dark:bg-white/[0.02]">
													<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-black/10 dark:text-white/10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
												</div>
												<div class="text-sm font-bold text-black/20 dark:text-white/20">未发现匹配的文章，尝试调整筛选条件。</div>
											</td>
										</tr>
									)}
								</tbody>
							</table>
						</div>
					</div>
				</form>
			</section>
		</div>

		<!-- Sidebar: Site Overview & Activity -->
		<aside class="space-y-10">
			<!-- Site Brand Preview -->
			<section data-admin-card class="card-base p-8">
				<div class="mb-8">
					<h3 class="text-xl font-black tracking-tight text-black/90 dark:text-white/95">个人信息</h3>
				</div>
				
				<div class="relative mb-16">
					<div class="h-28 w-full overflow-hidden rounded-[1.75rem] bg-black/5 dark:bg-white/5">
						{bannerPreview.isResolvable && <img src={bannerPreview.value} class="h-full w-full object-cover opacity-50" />}
					</div>
					<div class="absolute -bottom-10 left-8 h-24 w-24 overflow-hidden rounded-[2rem] border-[6px] border-[var(--card-bg)] bg-black/5 shadow-2xl dark:bg-white/5">
						{avatarPreview.isResolvable && <img src={avatarPreview.value} class="h-full w-full object-cover" />}
					</div>
				</div>

				<div class="space-y-6">
					<div>
						<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/30">站点标题</div>
						<div class="mt-1 text-base font-bold text-black/80 dark:text-white/80">{settings.title}</div>
					</div>
					<div>
						<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/30">关于摘要</div>
						<p class="mt-2 line-clamp-5 text-xs leading-relaxed text-black/50 dark:text-white/50 italic">
							"{aboutPreview || "尚未设置描述..."}"
						</p>
					</div>
				</div>

				<div class="mt-10">
					<a href="/admin/settings/" class="flex w-full items-center justify-center rounded-2xl bg-black/[0.04] py-4 text-xs font-black uppercase tracking-widest text-black/50 transition-all hover:bg-black/90 hover:text-white dark:bg-white/[0.04] dark:hover:bg-white/90 dark:hover:text-black">
						进入资料设置
					</a>
				</div>
			</section>

			<!-- Recent Activity -->
			<section data-admin-card class="card-base p-8">
				<div class="mb-8 flex items-center justify-between">
					<h3 class="text-xl font-black tracking-tight text-black/90 dark:text-white/95">系统动态</h3>
					<span class="rounded-full bg-emerald-500/10 px-2 py-0.5 text-[10px] font-black text-emerald-500 uppercase tracking-widest">Live</span>
				</div>

				<div class="relative space-y-8 before:absolute before:left-[11px] before:top-2 before:h-[calc(100%-16px)] before:w-px before:bg-black/5 dark:before:bg-white/5">
					{activities.slice(0, 6).map(activity => (
						<div class="relative pl-10">
							<div class="absolute left-0 top-1.5 h-[22px] w-[22px] rounded-full border-4 border-[var(--card-bg)] bg-black/10 dark:bg-white/20 shadow-sm"></div>
							<div class="text-[10px] font-black uppercase tracking-tighter text-black/30 dark:text-white/30">{activity.createdAt.split("T")[1].slice(0, 5)}</div>
							<div class="mt-1 text-xs font-bold text-black/80 dark:text-white/80 leading-snug">{activity.action}</div>
							<div class="mt-1 text-[10px] leading-relaxed text-black/40 dark:text-white/40">{activity.detail}</div>
						</div>
					))}
				</div>
			</section>
		</aside>
	</div>

