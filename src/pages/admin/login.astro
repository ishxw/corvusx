---
const error = Astro.url.searchParams.get("error");
---

<!DOCTYPE html>
<html lang="zh-CN" class="bg-[oklch(0.14_0.012_220)] text-[15px] text-white/90 md:text-[16px]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>登录 - Corvusx Admin</title>
		<style>
			@import "@fontsource/roboto/400.css";
			@import "@fontsource/roboto/700.css";
			@import "@fontsource/roboto/900.css";
			
			body {
				font-family: "Roboto", system-ui, sans-serif;
				-webkit-font-smoothing: antialiased;
			}
		</style>
	</head>
	<body class="min-h-screen overflow-x-hidden bg-[oklch(0.14_0.012_220)] text-white/90">
		<!-- Dynamic Background -->
		<div class="pointer-events-none fixed inset-0 overflow-hidden opacity-60">
			<div class="absolute -left-20 -top-20 h-[30rem] w-[30rem] rounded-full bg-[oklch(0.45_0.12_220/.4)] blur-[120px]"></div>
			<div class="absolute -right-20 top-[20vh] h-[25rem] w-[25rem] rounded-full bg-[oklch(0.35_0.08_180/.3)] blur-[120px]"></div>
			<div class="absolute bottom-[-10rem] left-[10vw] h-[20rem] w-[20rem] rounded-full bg-[oklch(0.4_0.1_250/.25)] blur-[100px]"></div>
		</div>

		<div class="relative mx-auto flex min-h-screen max-w-7xl items-center px-6 py-12 md:px-10">
			<div class="grid w-full gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center xl:gap-20">
				<!-- Left Content: Branding & Features -->
				<div class="hidden lg:block">
					<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-[10px] font-bold uppercase tracking-[0.25em] text-white/40 backdrop-blur-md">
						<span class="h-1.5 w-1.5 rounded-full bg-sky-400 animate-pulse"></span>
						Corvusx Admin
					</div>
					<h1 class="max-w-xl text-5xl font-black leading-[1.1] tracking-tight text-white md:text-6xl">
						管理你的<br/><span class="text-sky-400">数字足迹。</span>
					</h1>
					<p class="mt-8 max-w-lg text-lg leading-relaxed text-white/50">
						Corvusx 为你提供极致的写作与管理体验。在这里，每一行代码都转化为优雅的文字，每一张图片都能找到它的归宿。
					</p>
					
					<div class="mt-12 grid max-w-2xl gap-6 sm:grid-cols-2">
						<div class="group rounded-[2rem] border border-white/5 bg-white/[0.03] p-6 backdrop-blur-sm transition-all hover:bg-white/[0.06] hover:shadow-2xl hover:shadow-black/20">
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-2xl bg-sky-500/10 text-sky-400 transition-transform group-hover:scale-110">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
							</div>
							<div class="text-base font-bold text-white/90">内容创作</div>
							<p class="mt-2 text-sm leading-6 text-white/40">全功能 Markdown 编辑器，支持实时预览与本地草稿自动保存。</p>
						</div>
						<div class="group rounded-[2rem] border border-white/5 bg-white/[0.03] p-6 backdrop-blur-sm transition-all hover:bg-white/[0.06] hover:shadow-2xl hover:shadow-black/20">
							<div class="mb-4 flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-500/10 text-emerald-400 transition-transform group-hover:scale-110">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
							</div>
							<div class="text-base font-bold text-white/90">全站管控</div>
							<p class="mt-2 text-sm leading-6 text-white/40">站点标题、SEO、社交链接与导航配置，一切尽在掌握。</p>
						</div>
					</div>
				</div>

				<!-- Right Content: Login Form -->
				<div class="mx-auto w-full max-w-md lg:mx-0 lg:max-w-none">
					<form method="post" action="/admin/api/login/" class="relative overflow-hidden rounded-[2.5rem] border border-white/10 bg-white/[0.06] p-8 shadow-2xl shadow-black/40 backdrop-blur-xl md:p-10">
						<div class="mb-10 text-center lg:text-left">
							<div class="mb-4 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-white/40 lg:hidden">
								Corvusx Admin
							</div>
							<h2 class="text-3xl font-black tracking-tight text-white md:text-4xl">欢迎回来</h2>
							<p class="mt-4 text-sm leading-relaxed text-white/40">
								请输入你的管理员凭据以进入工作区。
							</p>
						</div>

						{error && (
							<div class="mb-8 flex items-center gap-3 rounded-2xl border border-rose-500/20 bg-rose-500/10 px-5 py-4 text-sm font-medium text-rose-300">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
								用户名或密码不正确
							</div>
						)}

						<div class="space-y-6">
							<label class="block">
								<div class="mb-2.5 px-1 text-xs font-bold uppercase tracking-widest text-white/40">用户名</div>
								<div class="relative group">
									<div class="absolute inset-y-0 left-0 flex items-center pl-4 text-white/30 group-focus-within:text-sky-400 transition-colors">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
									</div>
									<input
										name="username"
										type="text"
										required
										placeholder="admin"
										autocomplete="username"
										class="w-full rounded-2xl border border-white/5 bg-black/20 py-4 pl-12 pr-4 text-white placeholder:text-white/20 outline-none transition-all focus:border-sky-400/50 focus:bg-black/40 focus:ring-4 focus:ring-sky-400/10"
									/>
								</div>
							</label>

							<label class="block">
								<div class="mb-2.5 px-1 text-xs font-bold uppercase tracking-widest text-white/40">密码</div>
								<div class="relative group">
									<div class="absolute inset-y-0 left-0 flex items-center pl-4 text-white/30 group-focus-within:text-sky-400 transition-colors">
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
									</div>
									<input
										name="password"
										type="password"
										required
										placeholder="••••••••"
										autocomplete="current-password"
										class="w-full rounded-2xl border border-white/5 bg-black/20 py-4 pl-12 pr-4 text-white placeholder:text-white/20 outline-none transition-all focus:border-sky-400/50 focus:bg-black/40 focus:ring-4 focus:ring-sky-400/10"
									/>
								</div>
							</label>

							<button
								type="submit"
								class="relative flex w-full items-center justify-center gap-2 overflow-hidden rounded-2xl bg-sky-500 py-4 font-bold text-white shadow-xl shadow-sky-500/20 transition-all hover:bg-sky-400 hover:shadow-sky-500/30 active:scale-[0.98]"
							>
								登录后台
								<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
							</button>
						</div>

						<p class="mt-8 text-center text-xs leading-relaxed text-white/25 px-4">
							安全提示：登录会话将在关闭浏览器后过期。请确保在受信任的设备上操作。
						</p>
					</form>
				</div>
			</div>
		</div>
	</body>
</html>
