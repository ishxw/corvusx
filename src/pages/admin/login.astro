---
import { siteConfig } from "@/config";
import {
	AUTO_MODE,
	DARK_MODE,
	DEFAULT_THEME,
	LIGHT_MODE,
} from "@/constants/constants";
import { getRuntimeState } from "@/server/runtime-state";

const error = Astro.url.searchParams.get("error");
const minutes = Astro.url.searchParams.get("minutes");

let errorMessage = "";
if (error === "invalid" || error === "1") {
	errorMessage = "用户名或密码不正确。";
} else if (error === "rate-limit") {
	errorMessage = `尝试次数过多，请在 ${minutes || 5} 分钟后再试。`;
}

const { siteConfig: runtimeSiteConfig } = await getRuntimeState();
const siteTitle = runtimeSiteConfig?.title || siteConfig.title || "Corvusx";
---

<!DOCTYPE html>
<html
	lang="zh-CN"
	class="bg-[#fdfaff] selection:bg-purple-200 dark:bg-[oklch(0.14_0.012_280)]"
>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Hi there! - {siteTitle}</title>
		<style>
			@import "@fontsource/roboto/400.css";
			@import "@fontsource/roboto/700.css";
			@import "@fontsource/roboto/900.css";

			:root {
				--p-primary: #a78bfa;
				--p-secondary: #f472b6;
				--p-accent: #fbbf24;
				--login-text: #4b5563;
				--login-text-strong: #1f2937;
				--login-text-muted: #9ca3af;
				--login-surface: rgba(255, 255, 255, 0.8);
				--login-surface-border: #fff;
				--login-input-bg: rgba(245, 243, 255, 0.5);
				--login-input-border: transparent;
				--login-input-focus-bg: #fff;
				--login-input-focus-border: #ddd6fe;
				--login-error-bg: #fff1f2;
				--login-error-border: #ffe4e6;
				--login-error-text: #f43f5e;
				--login-page-bg: linear-gradient(135deg, #fdfaff 0%, #fff1f2 100%);
			}

			:root.dark {
				--p-primary: oklch(0.75 0.14 280);
				--p-secondary: oklch(0.72 0.16 340);
				--p-accent: oklch(0.82 0.15 95);
				--login-text: rgba(255, 255, 255, 0.78);
				--login-text-strong: rgba(255, 255, 255, 0.95);
				--login-text-muted: rgba(255, 255, 255, 0.45);
				--login-surface: rgba(20, 24, 36, 0.72);
				--login-surface-border: rgba(255, 255, 255, 0.08);
				--login-input-bg: rgba(255, 255, 255, 0.06);
				--login-input-border: rgba(255, 255, 255, 0.04);
				--login-input-focus-bg: rgba(255, 255, 255, 0.1);
				--login-input-focus-border: rgba(167, 139, 250, 0.5);
				--login-error-bg: rgba(244, 63, 94, 0.12);
				--login-error-border: rgba(244, 63, 94, 0.2);
				--login-error-text: #fda4af;
				--login-page-bg: linear-gradient(
					135deg,
					oklch(0.16 0.02 280) 0%,
					oklch(0.12 0.02 330) 100%
				);
			}

			body {
				font-family: "Roboto", system-ui, sans-serif;
				margin: 0;
				color: var(--login-text);
				background: var(--login-page-bg);
				overflow: hidden;
			}

			.cute-card {
				background: var(--login-surface);
				backdrop-filter: blur(20px);
				border: 4px solid var(--login-surface-border);
				box-shadow:
					0 10px 25px -5px rgba(167, 139, 250, 0.1),
					0 8px 10px -6px rgba(167, 139, 250, 0.1),
					0 0 0 1px rgba(167, 139, 250, 0.05);
			}

			.floating {
				animation: float 6s ease-in-out infinite;
			}

			@keyframes float {
				0%,
				100% {
					transform: translateY(0) rotate(0deg);
				}
				50% {
					transform: translateY(-20px) rotate(5deg);
				}
			}

			.blob {
				position: absolute;
				z-index: -1;
				filter: blur(60px);
				opacity: 0.4;
			}

			.btn-cute {
				background: linear-gradient(135deg, var(--p-primary) 0%, #8b5cf6 100%);
				box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
			}

			.btn-cute:hover {
				transform: translateY(-2px) scale(1.02);
				box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
			}

			input::placeholder {
				color: var(--login-text-muted);
			}

			.login-input {
				background: var(--login-input-bg);
				border-color: var(--login-input-border);
				color: var(--login-text-strong);
			}

			.login-input:focus {
				background: var(--login-input-focus-bg);
				border-color: var(--login-input-focus-border);
			}
		</style>
		<script
			is:inline
			define:vars={{ DEFAULT_THEME, LIGHT_MODE, DARK_MODE, AUTO_MODE }}
		>
			const theme = localStorage.getItem("theme") || DEFAULT_THEME;
			if (
				theme === DARK_MODE ||
				(theme === AUTO_MODE &&
					window.matchMedia("(prefers-color-scheme: dark)").matches)
			) {
				document.documentElement.classList.add("dark");
			} else if (theme === LIGHT_MODE) {
				document.documentElement.classList.remove("dark");
			} else {
				document.documentElement.classList.remove("dark");
			}
		</script>
	</head>
	<body class="relative flex min-h-screen items-center justify-center p-6">
		<div class="blob left-10 top-10 h-64 w-64 rounded-full bg-purple-300 dark:bg-purple-500/30"></div>
		<div class="blob bottom-10 right-10 h-80 w-80 rounded-full bg-pink-200 dark:bg-pink-500/20"></div>
		<div class="blob left-1/2 top-1/2 h-40 w-40 -translate-x-1/2 -translate-y-1/2 rounded-full bg-yellow-100 dark:bg-amber-300/15"></div>

		<main class="relative w-full max-w-[400px]">
			<div class="floating absolute -top-16 left-1/2 -translate-x-1/2">
				<div class="flex h-32 w-32 items-center justify-center rounded-[2rem] border-4 border-purple-50 bg-white shadow-xl dark:border-white/10 dark:bg-[oklch(0.2_0.02_280)]">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						class="h-16 w-16 text-purple-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
						<circle cx="12" cy="11" r="3"></circle>
					</svg>
				</div>
			</div>

			<div class="cute-card rounded-[3rem] p-10 pt-20">
				<div class="mb-10 text-center">
					<h1 class="mb-2 text-3xl font-black tracking-tight text-[var(--login-text-strong)]">
						{siteTitle} <span class="text-purple-500">Admin</span>
					</h1>
					<p class="text-sm font-medium text-[var(--login-text-muted)]">
						请验证身份以继续
					</p>
				</div>

				<form method="post" action="/admin/api/login/" class="space-y-6">
					{
						errorMessage && (
							<div
								class="rounded-2xl border-2 p-4 text-center text-xs font-bold"
								style={`background: var(--login-error-bg); border-color: var(--login-error-border); color: var(--login-error-text);`}
							>
								{errorMessage}
							</div>
						)
					}

					<div class="space-y-4">
						<input
							name="username"
							type="text"
							required
							placeholder="你的用户名"
							class="login-input w-full rounded-2xl border-2 px-6 py-4 text-sm font-bold outline-none transition-all"
						/>
						<input
							name="password"
							type="password"
							required
							placeholder="你的密码"
							class="login-input w-full rounded-2xl border-2 px-6 py-4 text-sm font-bold outline-none transition-all"
						/>
					</div>

					<button
						type="submit"
						class="btn-cute w-full rounded-2xl py-5 text-xs font-black uppercase tracking-widest text-white transition-all active:scale-95"
					>
						开始探索
					</button>
				</form>
			</div>

			<p class="mt-8 text-center text-[10px] font-black uppercase tracking-widest text-purple-300 dark:text-purple-300/50">
				Make with Love & Astro
			</p>
		</main>
	</body>
</html>
