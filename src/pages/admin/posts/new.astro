---
import MediaPickerModal from "@/components/admin/MediaPickerModal.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { listAdminPosts } from "@/server/post-store";

if (!Astro.locals.adminUser) {
	return Astro.redirect("/admin/login/");
}

const posts = await listAdminPosts();
const categorySuggestions = Array.from(
	new Set(posts.map((post) => post.category.trim()).filter(Boolean)),
).slice(0, 10);
const tagSuggestions = Array.from(
	new Set(
		posts.flatMap((post) => post.tags.map((tag) => tag.trim())).filter(Boolean),
	),
).slice(0, 16);
---

<AdminLayout
	title="创建新文章"
	description="开启一段新的创作旅程。文章将以 Markdown 格式保存至内容目录。"
>
	<form
		method="post"
		action="/admin/api/posts/"
		class="space-y-10 pb-24"
		data-admin-post-editor-form
		data-editor-id="admin-markdown-editor"
		data-preview-id="admin-markdown-preview"
		data-stats-id="admin-markdown-stats"
		data-status-id="admin-editor-status"
		data-restore-id="admin-restore-notice"
		data-timestamp-id="admin-editor-timestamp"
		data-autosave-key="corvusx-admin-new-post"
		data-enable-auto-slug="true"
	>
		<input type="hidden" name="mode" value="create" />
		<input type="hidden" name="intent" value="return" data-submit-intent />

		<div class="grid gap-6 lg:grid-cols-[1fr_380px]">
			<section class="card-base flex flex-col justify-between p-8 md:p-10" data-admin-card>
				<div class="flex items-start justify-between gap-4">
					<div>
						<div class="mb-2 flex items-center gap-3">
							<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/30">New Content</div>
							<span class="rounded-full bg-sky-500/10 px-2.5 py-1 text-[10px] font-black uppercase tracking-wider text-sky-600 shadow-sm dark:text-sky-400">
								Drafting
							</span>
						</div>
						<h2
							data-post-title-display
							data-empty-label="未命名文章"
							class="text-3xl font-black tracking-tight text-black/90 dark:text-white/95 leading-tight"
						>
							未命名文章
						</h2>
						<p class="mt-2 text-sm text-black/40 dark:text-white/40 italic">填入标题以开始，Slug 会根据标题自动生成。</p>
					</div>
				</div>

				<div class="mt-12 grid gap-5 sm:grid-cols-3">
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">发布日期</div>
						<div class="mt-1 text-sm font-bold text-black/70 dark:text-white/80">{new Date().toISOString().slice(0, 10)}</div>
					</div>
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">自动 Slug</div>
						<div class="mt-1 truncate text-sm font-bold text-black/70 dark:text-white/80 italic opacity-40 uppercase tracking-tighter">由标题驱动</div>
					</div>
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">备份同步</div>
						<div id="admin-editor-timestamp" class="mt-1 text-[10px] font-bold text-[var(--primary)] uppercase tracking-tighter">就绪</div>
					</div>
				</div>
			</section>

			<aside class="card-base flex flex-col justify-between p-8" data-admin-card>
				<div class="space-y-8">
					<div class="text-lg font-black tracking-tight text-black/90 dark:text-white/95">发布设置</div>

					<label class="group flex cursor-pointer items-center gap-5 rounded-2xl border border-black/5 bg-black/[0.02] p-5 transition-all hover:bg-white dark:border-white/5 dark:bg-white/[0.02] dark:hover:bg-black/40">
						<input type="checkbox" name="publishedState" checked class="h-6 w-6 accent-[var(--primary)]" />
						<div class="flex-1">
							<div class="text-sm font-black text-black/80 dark:text-white/90 uppercase tracking-widest">立即发布</div>
							<div class="text-[10px] text-black/30 dark:text-white/30 italic">取消勾选则作为草稿保存</div>
						</div>
					</label>
				</div>

				<div class="mt-8 flex gap-3">
					<div class="btn-plain flex-1 cursor-not-allowed rounded-2xl py-3.5 text-center text-[10px] font-black uppercase tracking-[0.2em] opacity-30">预览不可用</div>
				</div>
			</aside>
		</div>

		<section class="card-base p-8 md:p-10" data-admin-card>
			<div class="mb-10">
				<h2 class="text-2xl font-black tracking-tight text-black/90 dark:text-white/95">核心信息</h2>
				<p class="mt-2 text-sm text-black/40 dark:text-white/40 italic">文章的身份标识与分类标记。</p>
			</div>

			<div class="grid gap-10 lg:grid-cols-2">
				<div class="space-y-8">
					<label class="block">
						<div class="admin-label">文章标题 (Title)</div>
						<input name="title" required placeholder="例如：我的第一篇博客" class="w-full" />
					</label>
					<label class="block">
						<div class="admin-label">URL 路径 (Slug)</div>
						<input name="slug" required placeholder="my-post-slug" class="w-full font-mono" />
					</label>
					<div class="grid gap-6 sm:grid-cols-2">
						<label class="block">
							<div class="admin-label">发布日期</div>
							<input name="published" type="date" value={new Date().toISOString().slice(0, 10)} />
						</label>
						<label class="block">
							<div class="admin-label">计划发布 (可选)</div>
							<input name="publishAt" type="datetime-local" />
						</label>
					</div>
				</div>

				<div class="space-y-8">
					<label class="block">
						<div class="admin-label">封面图片 (Cover)</div>
						<div class="flex gap-3">
							<input id="image" name="image" data-media-input class="flex-1" />
							<button type="button" data-open-media-picker data-target-input="image" data-picker-label="为文章选择封面图" class="btn-plain shrink-0 rounded-2xl px-5 font-bold text-sm">选择</button>
						</div>
					</label>
					<div class="relative aspect-[21/9] w-full overflow-hidden rounded-[2.5rem] border-2 border-dashed border-black/5 bg-black/[0.02] dark:border-white/5 dark:bg-white/[0.02]">
						<img data-media-preview-for="image" alt="封面预览" class="hidden h-full w-full object-cover transition-opacity duration-700" />
						<div data-media-preview-empty="image" class="absolute inset-0 flex items-center justify-center text-[10px] font-black uppercase tracking-[0.2em] text-black/20 dark:text-white/10">
							Wait for image selection
						</div>
					</div>
				</div>
			</div>

			<div class="mt-12 space-y-10 border-t border-black/5 pt-10 dark:border-white/5">
				<div class="grid gap-10 lg:grid-cols-2">
					<label class="block">
						<div class="admin-label">分类</div>
						<input name="category" placeholder="技术, 生活..." class="w-full" />
						{categorySuggestions.length > 0 && (
							<div class="mt-5 flex flex-wrap gap-2">
								{categorySuggestions.map((item) => (
									<button type="button" data-category-suggestion={item} class="rounded-lg bg-black/[0.03] px-3 py-1.5 text-[10px] font-bold text-black/40 transition-all hover:bg-[var(--primary)] hover:text-white dark:bg-white/[0.03] dark:text-white/40">{item}</button>
								))}
							</div>
						)}
					</label>
					<label class="block">
						<div class="admin-label">标签</div>
						<input name="tags" placeholder="标签 1, 标签 2..." class="w-full" />
						{tagSuggestions.length > 0 && (
							<div class="mt-5 flex flex-wrap gap-2">
								{tagSuggestions.map((item) => (
									<button type="button" data-tag-suggestion={item} class="rounded-lg bg-black/[0.03] px-3 py-1.5 text-[10px] font-bold text-black/40 transition-all hover:bg-[var(--primary)] hover:text-white dark:bg-white/[0.03] dark:text-white/40">#{item}</button>
								))}
							</div>
						)}
					</label>
				</div>
				<label class="block">
					<div class="admin-label">文章摘要 (Description)</div>
					<textarea name="description" rows="3" placeholder="一段简洁的文字介绍..." class="w-full"></textarea>
				</label>
			</div>
		</section>

		<section class="card-base overflow-hidden" data-admin-card>
			<div class="flex flex-col border-b border-black/5 bg-black/[0.01] p-8 dark:border-white/5 dark:bg-white/[0.01] lg:flex-row lg:items-center lg:justify-between">
				<div class="mb-6 lg:mb-0">
					<h3 class="text-xl font-black tracking-tight text-black/90 dark:text-white/95">正文编辑器</h3>
					<div id="admin-editor-status" class="mt-1 text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/20">加载中...</div>
				</div>
				<div data-admin-editor-toolbar class="flex flex-wrap gap-2">
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{[
							{ id: "image", label: "图", icon: "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12" },
							{ id: "video", label: "影", icon: "M23 7l-7 5 7 5V7zM1 5h14v14H1V5z" },
							{ id: "github", label: "Git", icon: "M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" },
						].map((tool) => (
							<button type="button" data-snippet={tool.id} class="flex h-10 w-10 items-center justify-center rounded-lg bg-white shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40" title={tool.label}>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d={tool.icon}/></svg>
							</button>
						))}
					</div>
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{[
							{ id: "admonitionNote", label: "Note" },
							{ id: "admonitionTip", label: "Tip" },
							{ id: "admonitionWarning", label: "Warn" },
							{ id: "admonitionCaution", label: "Caut" },
						].map((tool) => (
							<button type="button" data-snippet={tool.id} class="rounded-lg bg-white px-3 text-[10px] font-black uppercase tracking-tighter shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40">{tool.label}</button>
						))}
					</div>
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{["code", "codeTs", "codeTitle", "codeTerminal", "codeMarkers", "mathBlock", "linkCard", "spoiler", "collapse"].map((id) => (
							<button type="button" data-snippet={id} class="rounded-lg bg-white px-3 text-[10px] font-bold uppercase tracking-tighter shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40">{id.replace("code", "").replace("admonition", "")}</button>
						))}
					</div>
				</div>
			</div>

			<div id="admin-restore-notice" class="hidden border-b border-amber-500/20 bg-amber-500/10 px-8 py-4 text-xs font-black uppercase tracking-widest text-amber-600">备份就绪：本地有上次未提交的草稿，点击可恢复。</div>

			<div class="grid lg:grid-cols-2">
				<div class="flex flex-col border-r border-black/5 dark:border-white/5">
					<textarea id="admin-markdown-editor" name="body" rows="30" class="w-full resize-none overflow-hidden !border-none !bg-transparent !p-10 font-mono !text-sm leading-relaxed outline-none" placeholder="在此开始你的创作..."></textarea>
				</div>
				<div class="flex flex-col bg-black/[0.005] dark:bg-white/[0.005]">
					<div id="admin-markdown-preview" class="custom-md !max-w-none prose prose-sm !p-10 dark:prose-invert overflow-y-auto scrollbar-thin"></div>
				</div>
			</div>

			<div class="flex items-center justify-between border-t border-black/5 bg-black/[0.01] px-10 py-5 dark:border-white/5 dark:bg-white/[0.01]">
				<div id="admin-markdown-stats" class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/20">0 字 / 0 分钟</div>
				<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/15 dark:text-white/10">Corvusx Engine v3.0</div>
			</div>
		</section>

		<div class="fixed bottom-10 left-1/2 z-50 flex w-full max-w-7xl -translate-x-1/2 items-end justify-end px-6">
			<div class="flex items-center gap-4 rounded-[3rem] border border-white/10 bg-black/80 p-3 pl-8 shadow-2xl backdrop-blur-2xl dark:bg-white/10">
				<div class="hidden pr-6 text-[10px] font-black uppercase tracking-[0.3em] text-white/30 xl:block">操作集</div>
				<button type="submit" data-submit-intent-value="return" class="btn-regular rounded-[2.5rem] px-10 py-4 text-[10px] font-black uppercase tracking-widest shadow-xl">保存并返回</button>
				<button type="submit" data-submit-intent-value="preview" class="btn-plain rounded-[2.5rem] px-8 py-4 text-[10px] font-black uppercase tracking-widest text-white/50 hover:text-white transition-colors">保存并预览</button>
			</div>
		</div>
	</form>

	<script>
		import "@/components/admin/PostEditorEnhancer.client";
	</script>

	<script is:inline>
		const form = document.querySelector('form[action="/admin/api/posts/"]');
		const intentField = document.querySelector("[data-submit-intent]");
		form?.addEventListener("submit", (event) => {
			const submitter = event.submitter;
			if (intentField instanceof HTMLInputElement && submitter instanceof HTMLElement) {
				intentField.value = submitter.getAttribute("data-submit-intent-value") || "return";
			}
		});
	</script>

	<MediaPickerModal modalId="admin-media-picker" />
</AdminLayout>
