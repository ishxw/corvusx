---
import MediaPickerModal from "@/components/admin/MediaPickerModal.astro";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAdminPostStatus } from "@/server/admin-post-status";
import { getAdminPost, listAdminPosts } from "@/server/post-store";

if (!Astro.locals.adminUser) {
	return Astro.redirect("/admin/login/");
}

const slug = Astro.params.slug || "";
const post = await getAdminPost(slug);

if (!post) {
	return Astro.redirect("/admin/");
}

const publishAtValue = post.publishAt ? post.publishAt.slice(0, 16) : "";
const statusInfo = getAdminPostStatus(post);
const previewUrl = `/posts/${post.slug}/?preview=1`;
const posts = await listAdminPosts();
const categorySuggestions = Array.from(
	new Set(posts.map((item) => item.category.trim()).filter(Boolean)),
).slice(0, 10);
const tagSuggestions = Array.from(
	new Set(
		posts.flatMap((item) => item.tags.map((tag) => tag.trim())).filter(Boolean),
	),
).slice(0, 16);
---

<AdminLayout
	title="编辑文章"
	description={post.title}
>
	<form
		method="post"
		action="/admin/api/posts/"
		class="space-y-10 pb-24"
		data-admin-post-editor-form
		data-editor-id="admin-markdown-editor"
		data-preview-id="admin-markdown-preview"
		data-stats-id="admin-markdown-stats"
		data-status-id="admin-editor-status"
		data-restore-id="admin-restore-notice"
		data-timestamp-id="admin-editor-timestamp"
		data-autosave-key={`corvusx-admin-edit-${post.slug}`}
	>
		<input type="hidden" name="intent" value="return" data-submit-intent />
		<input type="hidden" name="mode" value="update" />
		<input type="hidden" name="originalSlug" value={post.slug} />

		<div class="grid gap-6 lg:grid-cols-[1fr_380px]">
			<section class="card-base flex flex-col justify-between p-8 md:p-10" data-admin-card>
				<div class="flex items-start justify-between gap-4">
					<div>
						<div class="mb-2 flex items-center gap-3">
							<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/30">Post Lifecycle</div>
							<span class:list={["rounded-full px-2.5 py-1 text-[10px] font-black uppercase tracking-wider shadow-sm", statusInfo.badgeClass]}>
								{statusInfo.label}
							</span>
						</div>
						<h2 class="text-3xl font-black tracking-tight text-black/90 dark:text-white/95 leading-tight">{post.title}</h2>
						<p class="mt-2 text-sm text-black/40 dark:text-white/40 italic">{statusInfo.description}</p>
					</div>
				</div>

				<div class="mt-12 grid gap-5 sm:grid-cols-3">
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">路径 Slug</div>
						<div class="mt-1 truncate text-sm font-bold text-black/70 dark:text-white/80" title={post.slug}>{post.slug}</div>
					</div>
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">计划发布</div>
						<div class="mt-1 text-sm font-bold text-black/70 dark:text-white/80">{post.publishAt ? post.publishAt.replace("T", " ") : "立即生效"}</div>
					</div>
					<div class="rounded-[1.5rem] bg-black/[0.03] p-6 dark:bg-white/[0.03]">
						<div class="text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/30">编辑器状态</div>
						<div id="admin-editor-timestamp" class="mt-1 text-[10px] font-bold text-[var(--primary)] uppercase tracking-tighter">待同步...</div>
					</div>
				</div>
			</section>

			<aside class="card-base flex flex-col justify-between p-8" data-admin-card>
				<div class="space-y-8">
					<div class="text-lg font-black tracking-tight text-black/90 dark:text-white/95">发布设置</div>

					<label class="group flex cursor-pointer items-center gap-5 rounded-2xl border border-black/5 bg-black/[0.02] p-5 transition-all hover:bg-white dark:border-white/5 dark:bg-white/[0.02] dark:hover:bg-black/40">
						<input type="checkbox" name="publishedState" checked={!post.draft} class="h-6 w-6 accent-[var(--primary)]" />
						<div class="flex-1">
							<div class="text-sm font-black text-black/80 dark:text-white/90 uppercase tracking-widest">公开发布</div>
							<div class="text-[10px] text-black/30 dark:text-white/30 italic">取消勾选则存为草稿</div>
						</div>
					</label>
				</div>

				<div class="mt-8 flex gap-3">
					<a href={previewUrl} target="_blank" class="btn-plain flex-1 rounded-2xl py-3.5 text-[10px] font-black uppercase tracking-[0.2em]">前台预览</a>
					<button type="button" id="copy-preview-link" class="btn-plain shrink-0 rounded-2xl px-5 py-3.5 transition-all hover:text-[var(--primary)]" title="复制预览链接">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
					</button>
				</div>
			</aside>
		</div>

		<section class="card-base p-8 md:p-10" data-admin-card>
			<div class="mb-10">
				<h2 class="text-2xl font-black tracking-tight text-black/90 dark:text-white/95">元数据管理</h2>
				<p class="mt-2 text-sm text-black/40 dark:text-white/40 italic">控制文章的 SEO 与分类体系。</p>
			</div>

			<div class="grid gap-10 lg:grid-cols-2">
				<div class="space-y-8">
					<label class="block">
						<div class="admin-label">文章标题 (Title)</div>
						<input name="title" required value={post.title} placeholder="输入文章标题" class="w-full" />
					</label>
					<label class="block">
						<div class="admin-label">URL 路径 (Slug)</div>
						<input name="slug" required value={post.slug} placeholder="my-post-slug" class="w-full font-mono" />
					</label>
					<div class="grid gap-6 sm:grid-cols-2">
						<label class="block">
							<div class="admin-label">发布日期</div>
							<input name="published" type="date" value={post.published} />
						</label>
						<label class="block">
							<div class="admin-label">计划发布</div>
							<input name="publishAt" type="datetime-local" value={publishAtValue} />
						</label>
					</div>
				</div>

				<div class="space-y-8">
					<label class="block">
						<div class="admin-label">封面图片 (Cover)</div>
						<div class="flex gap-3">
							<input id="image" name="image" value={post.image} data-media-input class="flex-1" />
							<button type="button" data-open-media-picker data-target-input="image" data-picker-label="为文章选择封面图" class="btn-plain shrink-0 rounded-2xl px-5 font-bold text-sm">选择</button>
						</div>
					</label>
					<div class="relative aspect-[21/9] w-full overflow-hidden rounded-[2.5rem] border-2 border-dashed border-black/5 bg-black/[0.02] dark:border-white/5 dark:bg-white/[0.02]">
						<img data-media-preview-for="image" alt="封面预览" class:list={["h-full w-full object-cover transition-opacity duration-700", !post.image && "opacity-0"]} src={post.image || undefined} />
						<div data-media-preview-empty="image" class:list={["absolute inset-0 flex items-center justify-center text-[10px] font-black uppercase tracking-[0.2em] text-black/20 dark:text-white/10", post.image && "hidden"]}>
							No Image Selected
						</div>
					</div>
				</div>
			</div>

			<div class="mt-12 space-y-10 border-t border-black/5 pt-10 dark:border-white/5">
				<div class="grid gap-10 lg:grid-cols-2">
					<label class="block">
						<div class="admin-label">分类</div>
						<input name="category" value={post.category} placeholder="单个分类" class="w-full" />
						{categorySuggestions.length > 0 && (
							<div class="mt-5 flex flex-wrap gap-2">
								{categorySuggestions.map((item) => (
									<button type="button" data-category-suggestion={item} class="rounded-lg bg-black/[0.03] px-3 py-1.5 text-[10px] font-bold text-black/40 transition-all hover:bg-[var(--primary)] hover:text-white dark:bg-white/[0.03] dark:text-white/40">{item}</button>
								))}
							</div>
						)}
					</label>
					<label class="block">
						<div class="admin-label">标签</div>
						<input name="tags" value={post.tags.join(", ")} placeholder="多个标签逗号分隔" class="w-full" />
						{tagSuggestions.length > 0 && (
							<div class="mt-5 flex flex-wrap gap-2">
								{tagSuggestions.map((item) => (
									<button type="button" data-tag-suggestion={item} class="rounded-lg bg-black/[0.03] px-3 py-1.5 text-[10px] font-bold text-black/40 transition-all hover:bg-[var(--primary)] hover:text-white dark:bg-white/[0.03] dark:text-white/40">#{item}</button>
								))}
							</div>
						)}
					</label>
				</div>
				<label class="block">
					<div class="admin-label">文章摘要 (Description)</div>
					<textarea name="description" rows="3" placeholder="一段简洁的文字介绍..." class="w-full">{post.description}</textarea>
				</label>
			</div>
		</section>

		<section class="card-base overflow-hidden" data-admin-card>
			<div class="flex flex-col border-b border-black/5 bg-black/[0.01] p-8 dark:border-white/5 dark:bg-white/[0.01] lg:flex-row lg:items-center lg:justify-between">
				<div class="mb-6 lg:mb-0">
					<h3 class="text-xl font-black tracking-tight text-black/90 dark:text-white/95">正文编辑器</h3>
					<div id="admin-editor-status" class="mt-1 text-[10px] font-black uppercase tracking-widest text-black/30 dark:text-white/20">加载中...</div>
				</div>
				<div data-admin-editor-toolbar class="flex flex-wrap gap-2">
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{[
							{ id: "image", label: "图", icon: "M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12" },
							{ id: "video", label: "影", icon: "M23 7l-7 5 7 5V7zM1 5h14v14H1V5z" },
							{ id: "github", label: "Git", icon: "M9 19c-5 1.5-5-2.5-7m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" },
						].map((tool) => (
							<button type="button" data-snippet={tool.id} class="flex h-10 w-10 items-center justify-center rounded-lg bg-white shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40" title={tool.label}>
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d={tool.icon}/></svg>
							</button>
						))}
					</div>
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{[
							{ id: "admonitionNote", label: "Note" },
							{ id: "admonitionTip", label: "Tip" },
							{ id: "admonitionWarning", label: "Warn" },
							{ id: "admonitionCaution", label: "Caut" },
						].map((tool) => (
							<button type="button" data-snippet={tool.id} class="rounded-lg bg-white px-3 text-[10px] font-black uppercase tracking-tighter shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40">{tool.label}</button>
						))}
					</div>
					<div class="flex gap-1.5 rounded-xl bg-black/5 p-1 dark:bg-white/5">
						{["code", "codeTs", "codeTitle", "codeTerminal", "codeMarkers", "mathBlock", "linkCard", "spoiler", "collapse"].map((id) => (
							<button type="button" data-snippet={id} class="rounded-lg bg-white px-3 text-[10px] font-bold uppercase tracking-tighter shadow-sm transition-all hover:text-[var(--primary)] dark:bg-black/40">{id.replace("code", "").replace("admonition", "")}</button>
						))}
					</div>
				</div>
			</div>

			<div id="admin-restore-notice" class="hidden border-b border-amber-500/20 bg-amber-500/10 px-8 py-4 text-xs font-black uppercase tracking-widest text-amber-600">备份就绪：本地有较新的草稿，点击可恢复。</div>

			<div class="grid lg:grid-cols-2">
				<div class="flex flex-col border-r border-black/5 dark:border-white/5">
					<textarea id="admin-markdown-editor" name="body" rows="30" class="w-full !border-none !bg-transparent !p-10 font-mono !text-sm leading-relaxed outline-none scrollbar-thin" placeholder="在此开始你的创作...">{post.body}</textarea>
				</div>
				<div class="flex flex-col bg-black/[0.005] dark:bg-white/[0.005]">
					<div id="admin-markdown-preview" class="custom-md !max-w-none prose prose-sm !p-10 dark:prose-invert overflow-y-auto scrollbar-thin"></div>
				</div>
			</div>

			<div class="flex items-center justify-between border-t border-black/5 bg-black/[0.01] px-10 py-5 dark:border-white/5 dark:bg-white/[0.01]">
				<div id="admin-markdown-stats" class="text-[10px] font-black uppercase tracking-[0.25em] text-black/30 dark:text-white/20">0 字 / 0 分钟</div>
				<div class="text-[10px] font-black uppercase tracking-[0.25em] text-black/15 dark:text-white/10">Corvusx Engine v3.0</div>
			</div>
		</section>

		<div class="fixed bottom-10 left-1/2 z-50 flex w-full max-w-7xl -translate-x-1/2 items-center justify-between px-6">
			<button type="button" data-delete-post-btn data-confirm="确认彻底删除这篇文章吗？" class="group flex items-center gap-3 rounded-[2.5rem] border border-rose-500/20 bg-rose-500/10 px-10 py-5 text-[10px] font-black uppercase tracking-widest text-rose-500 transition-all hover:bg-rose-500 hover:text-white shadow-2xl">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
				彻底删除
			</button>

			<div class="flex items-center gap-4 rounded-[3rem] border border-white/10 bg-black/80 p-3 pl-8 shadow-2xl backdrop-blur-2xl dark:bg-white/10">
				<div class="hidden pr-6 text-[10px] font-black uppercase tracking-[0.3em] text-white/30 xl:block">操作集</div>
				<button type="submit" data-submit-intent-value="return" class="btn-regular rounded-[2.5rem] px-10 py-4 text-[10px] font-black uppercase tracking-widest shadow-xl">保存并返回</button>
				<button type="submit" data-submit-intent-value="preview" class="btn-plain rounded-[2.5rem] px-8 py-4 text-[10px] font-black uppercase tracking-widest text-white/50 hover:text-white transition-colors">保存并预览</button>
			</div>
		</div>
	</form>

	<script>
		import "@/components/admin/PostEditorEnhancer.client";
	</script>

	<script is:inline define:vars={{ previewUrl }}>
		const form = document.querySelector('form[action="/admin/api/posts/"]');
		const intentField = document.querySelector("[data-submit-intent]");
		form?.addEventListener("submit", (event) => {
			const submitter = event.submitter;
			if (intentField instanceof HTMLInputElement && submitter instanceof HTMLElement) {
				intentField.value = submitter.getAttribute("data-submit-intent-value") || "return";
			}
		});

		const deleteBtn = document.querySelector("[data-delete-post-btn]");
		deleteBtn?.addEventListener("click", async () => {
			const confirmed = await window.showAdminConfirm?.(deleteBtn.dataset.confirm);
			if (confirmed) {
				const deleteForm = document.createElement("form");
				deleteForm.method = "POST";
				deleteForm.action = "/admin/api/posts/delete/";

				const slugInput = document.createElement("input");
				slugInput.type = "hidden";
				slugInput.name = "slug";
				slugInput.value = window.location.pathname.split("/").filter(Boolean).pop();
				deleteForm.appendChild(slugInput);

				document.body.appendChild(deleteForm);
				deleteForm.submit();
			}
		});

		document.getElementById("copy-preview-link")?.addEventListener("click", async () => {
			await navigator.clipboard.writeText(window.location.origin + previewUrl);
			window.showAdminToast?.("预览链接已复制到剪贴板！");
		});
	</script>

	<MediaPickerModal modalId="admin-media-picker" />
</AdminLayout>
