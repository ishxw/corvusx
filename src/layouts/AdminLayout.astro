---
import "@fontsource/roboto/400.css";
import "@fontsource/roboto/500.css";
import "@fontsource/roboto/700.css";
import "@fontsource-variable/jetbrains-mono";
import "@/styles/main.css";
import "@/styles/markdown.css";
import "@/styles/markdown-extend.styl";
import ConfigCarrier from "@components/ConfigCarrier.astro";
import { profileConfig, siteConfig } from "@/config";
import { defaultFavicons } from "@/constants/icon";
import { resolveFavicons } from "@/server/favicon";
import { getRuntimeState } from "@/server/runtime-state";
import type { Favicon } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	title: string;
	description?: string;
	backHref?: string;
	backLabel?: string;
	success?: string | null;
	error?: string | null;
}

const {
	title,
	description = "",
	backHref = "/admin/",
	backLabel = "返回后台首页",
	success = null,
	error = null,
} = Astro.props;

const { siteConfig: runtimeSiteConfig, profileConfig: runtimeProfileConfig } =
	await getRuntimeState();

const activeSiteConfig = runtimeSiteConfig || siteConfig;
const activeProfileConfig = runtimeProfileConfig || profileConfig;
const configHue = activeSiteConfig.themeColor.hue;
const siteLang = activeSiteConfig.lang.replace("_", "-");
const siteTitle = activeSiteConfig.title || "Corvusx";
const pageTitle = `${title} - ${siteTitle} 控制台`;
const rawFavicons: Favicon[] =
	activeSiteConfig.favicon.length > 0
		? activeSiteConfig.favicon
		: defaultFavicons;
const favicons = await resolveFavicons(rawFavicons);
---

<!DOCTYPE html>
<html lang={siteLang} class="bg-[var(--page-bg)] text-[15px] transition-colors duration-300 md:text-[16px]">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="author" content={activeProfileConfig.name} />
		<title>{pageTitle}</title>
		{favicons.map((favicon) => (
			<link
				rel="icon"
				href={favicon.href.startsWith("/") ? url(favicon.href) : favicon.href}
				type={favicon.type}
				sizes={favicon.sizes}
				media={favicon.theme && `(prefers-color-scheme: ${favicon.theme})`}
			/>
		))}
		<style define:vars={{ adminHue: String(configHue) }}></style>
		<script is:inline define:vars={{ configHue }}>
			// Load the theme from local storage
			const theme = localStorage.getItem('theme') || 'auto';
			if (theme === 'dark' || (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}

			// Set the theme for Expressive Code
			document.documentElement.setAttribute('data-theme', 'github-dark');

			// Load the hue from local storage
			const hue = localStorage.getItem('hue') || configHue;
			document.documentElement.style.setProperty('--hue', hue);
		</script>
	</head>
	<body
		data-admin
		data-no-swup
		class="min-h-screen bg-[var(--page-bg)] text-black/90 selection:bg-[var(--selection-bg)] dark:text-white/90"
	>
		<ConfigCarrier />
		
		<!-- Toast Container -->
		<div id="admin-toast-container" class="fixed right-6 top-6 z-[200] flex flex-col gap-3 pointer-events-none"></div>

		<script is:inline>
			// Scroll Restoration Logic
			(function() {
				const scrollKey = 'corvusx_admin_scroll_state_v2';
				const maxAgeMs = 5 * 60 * 1000;
				const maxWaitMs = 1500;
				const stableFrameCount = 4;

				if ('scrollRestoration' in history) {
					history.scrollRestoration = 'manual';
				}

				const getScrollMetrics = () => {
					const doc = document.documentElement;
					const maxScroll = Math.max(0, doc.scrollHeight - window.innerHeight);
					const scrollY = window.scrollY || doc.scrollTop || 0;
					return {
						scrollY,
						maxScroll,
						ratio: maxScroll > 0 ? scrollY / maxScroll : 0,
					};
				};

				const saveScrollState = () => {
					const metrics = getScrollMetrics();
					sessionStorage.setItem(
						scrollKey,
						JSON.stringify({
							path: window.location.pathname,
							scrollY: metrics.scrollY,
							maxScroll: metrics.maxScroll,
							ratio: metrics.ratio,
							timestamp: Date.now(),
						}),
					);
				};

				const readScrollState = () => {
					try {
						const raw = sessionStorage.getItem(scrollKey);
						if (!raw) return null;
						const parsed = JSON.parse(raw);
						if (!parsed || typeof parsed !== 'object') return null;
						return parsed;
					} catch {
						return null;
					}
				};

				const savedState = readScrollState();
				if (
					savedState &&
					savedState.path === window.location.pathname &&
					typeof savedState.timestamp === 'number' &&
					Date.now() - savedState.timestamp <= maxAgeMs
				) {
					let lastHeight = -1;
					let stableFrames = 0;
					let restored = false;
					const startedAt = performance.now();

					const restoreScroll = () => {
						if (restored) return;
						const metrics = getScrollMetrics();
						const target =
							typeof savedState.maxScroll === 'number' && savedState.maxScroll > 0
								? Math.round((savedState.ratio || 0) * metrics.maxScroll)
								: Math.max(0, Number(savedState.scrollY) || 0);
						window.scrollTo(0, Math.min(target, metrics.maxScroll));
						restored = true;
						sessionStorage.removeItem(scrollKey);
					};

					const waitForStableLayout = () => {
						if (restored) return;
						const currentHeight = document.documentElement.scrollHeight;
						if (currentHeight === lastHeight) {
							stableFrames += 1;
						} else {
							lastHeight = currentHeight;
							stableFrames = 0;
						}

						const elapsed = performance.now() - startedAt;
						if (stableFrames >= stableFrameCount || elapsed >= maxWaitMs) {
							restoreScroll();
							return;
						}

						requestAnimationFrame(waitForStableLayout);
					};

					requestAnimationFrame(waitForStableLayout);
					window.addEventListener('load', restoreScroll, { once: true });
				}

				window.addEventListener('beforeunload', saveScrollState);
				window.addEventListener('pagehide', saveScrollState);
				document.addEventListener(
					'submit',
					() => {
						saveScrollState();
					},
					true,
				);
				document.addEventListener(
					'click',
					(event) => {
						const link = event.target.closest('a');
						if (!(link instanceof HTMLAnchorElement)) return;
						if (link.origin !== window.location.origin) return;
						saveScrollState();
					},
					true,
				);
			})();
		</script>

		<!-- Subtle Background blobs -->
		<div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden opacity-40 transition-opacity duration-500">
			<div class="absolute -left-24 -top-24 h-[32rem] w-[32rem] rounded-full bg-[oklch(0.85_0.12_var(--hue))] blur-[100px] dark:bg-[oklch(0.3_0.08_var(--hue))]"></div>
			<div class="absolute -right-12 top-[15vh] h-[28rem] w-[28rem] rounded-full bg-[oklch(0.9_0.08_var(--hue))] blur-[100px] dark:bg-[oklch(0.25_0.06_var(--hue))]"></div>
			<div class="absolute bottom-[-10rem] left-[20vw] h-[24rem] w-[24rem] rounded-full bg-[oklch(0.92_0.04_var(--hue))] blur-[100px] dark:bg-[oklch(0.22_0.04_var(--hue))]"></div>
		</div>

		<div class="relative mx-auto max-w-7xl px-6 py-10 md:px-8 lg:px-12">
			<header class="mb-10 flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
				<div class="space-y-3">
					<div class="inline-flex items-center gap-2 rounded-full border border-black/5 bg-white/40 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-black/40 backdrop-blur-md dark:border-white/5 dark:bg-white/5 dark:text-white/40">
						<span class="h-1.5 w-1.5 rounded-full bg-[var(--primary)] animate-pulse"></span>
						{siteTitle} Admin
					</div>
					<h1 class="text-3xl font-extrabold tracking-tight text-black/90 dark:text-white/95 md:text-4xl lg:text-5xl">
						{title}
					</h1>
					{description && (
						<p class="max-w-2xl text-sm leading-relaxed text-black/50 dark:text-white/50 md:text-base">
							{description}
						</p>
					)}
				</div>

				<nav class="flex items-center gap-3">
					<a href={backHref} data-admin-plain-btn class="group flex items-center gap-2 rounded-2xl px-5 py-3 font-semibold transition-all hover:ring-2 hover:ring-[var(--primary)]/20">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
						{backLabel}
					</a>
				</nav>
			</header>

			<main>
				<slot />
			</main>
		</div>

		<script is:inline define:vars={{ success, error }}>
			// Global Toast Logic
			window.showAdminToast = (message, type = 'success') => {
				const container = document.getElementById('admin-toast-container');
				if (!container) return;

				const toast = document.createElement('div');
				toast.className = `pointer-events-auto flex items-center gap-3 rounded-2xl border px-6 py-4 shadow-2xl backdrop-blur-xl transition-all duration-500 translate-x-10 opacity-0 ${
					type === 'success' 
						? 'border-emerald-500/20 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400' 
						: 'border-rose-500/20 bg-rose-500/10 text-rose-600 dark:text-rose-400'
				}`;
				
				const icon = type === 'success' 
					? '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>'
					: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';

				toast.innerHTML = `${icon}<span class="text-sm font-bold">${message}</span>`;
				container.prepend(toast);

				// Animation
				requestAnimationFrame(() => {
					toast.classList.remove('translate-x-10', 'opacity-0');
				});

				// Auto remove
				setTimeout(() => {
					toast.classList.add('opacity-0', 'scale-95');
					setTimeout(() => toast.remove(), 500);
				}, 4000);
			};

			// Global Custom Dialog Logic
			window.showAdminConfirm = (message) => {
				return new Promise((resolve) => {
					const overlay = document.createElement('div');
					overlay.className = 'fixed inset-0 z-[300] flex items-center justify-center bg-black/40 p-6 backdrop-blur-sm transition-opacity duration-300 opacity-0';
					overlay.innerHTML = `
						<div class="w-full max-w-sm scale-95 rounded-[2.5rem] border border-black/5 bg-white p-8 shadow-2xl transition-transform duration-300 dark:border-white/5 dark:bg-[var(--card-bg)]">
							<div class="mb-6 text-center text-lg font-bold text-black/90 dark:text-white/95">${message}</div>
							<div class="flex gap-4">
								<button id="confirm-cancel" class="flex-1 rounded-2xl bg-black/5 py-4 text-sm font-bold text-black/40 transition-colors hover:bg-black/10 dark:bg-white/5 dark:text-white/40 dark:hover:bg-white/10">取消</button>
								<button id="confirm-ok" class="flex-1 rounded-2xl bg-[var(--primary)] py-4 text-sm font-bold text-white shadow-lg shadow-[var(--primary)]/20 transition-transform active:scale-95">确认</button>
							</div>
						</div>
					`;
					document.body.appendChild(overlay);
					requestAnimationFrame(() => {
						overlay.classList.remove('opacity-0');
						overlay.firstElementChild.classList.remove('scale-95');
					});

					const cleanup = (value) => {
						overlay.classList.add('opacity-0');
						overlay.firstElementChild.classList.add('scale-95');
						setTimeout(() => {
							overlay.remove();
							resolve(value);
						}, 300);
					};

					overlay.querySelector('#confirm-ok').onclick = () => cleanup(true);
					overlay.querySelector('#confirm-cancel').onclick = () => cleanup(false);
				});
			};

			window.showAdminAlert = (message, title = '提醒') => {
				return new Promise((resolve) => {
					const overlay = document.createElement('div');
					overlay.className = 'fixed inset-0 z-[300] flex items-center justify-center bg-black/40 p-6 backdrop-blur-sm transition-opacity duration-300 opacity-0';
					overlay.innerHTML = `
						<div class="w-full max-w-sm scale-95 rounded-[2.5rem] border border-black/5 bg-white p-8 shadow-2xl transition-transform duration-300 dark:border-white/5 dark:bg-[var(--card-bg)]">
							<div class="mb-2 text-center text-xs font-black uppercase tracking-widest text-black/30 dark:text-white/30">${title}</div>
							<div class="mb-8 text-center text-lg font-bold text-black/90 dark:text-white/95">${message}</div>
							<button id="alert-ok" class="w-full rounded-2xl bg-[var(--primary)] py-4 text-sm font-bold text-white shadow-lg shadow-[var(--primary)]/20 transition-transform active:scale-95">知道了</button>
						</div>
					`;
					document.body.appendChild(overlay);
					requestAnimationFrame(() => {
						overlay.classList.remove('opacity-0');
						overlay.firstElementChild.classList.remove('scale-95');
					});

					const cleanup = () => {
						overlay.classList.add('opacity-0');
						overlay.firstElementChild.classList.add('scale-95');
						setTimeout(() => {
							overlay.remove();
							resolve();
						}, 300);
					};

					overlay.querySelector('#alert-ok').onclick = cleanup;
				});
			};

			window.showAdminPrompt = (message, defaultValue = '', title = '输入') => {
				return new Promise((resolve) => {
					const overlay = document.createElement('div');
					overlay.className = 'fixed inset-0 z-[300] flex items-center justify-center bg-black/40 p-6 backdrop-blur-sm transition-opacity duration-300 opacity-0';
					overlay.innerHTML = `
						<div class="w-full max-w-sm scale-95 rounded-[2.5rem] border border-black/5 bg-white p-8 shadow-2xl transition-transform duration-300 dark:border-white/5 dark:bg-[var(--card-bg)]">
							<div class="mb-2 text-center text-xs font-black uppercase tracking-widest text-black/30 dark:text-white/30">${title}</div>
							<div class="mb-6 text-center text-lg font-bold text-black/90 dark:text-white/95">${message}</div>
							<div class="mb-6">
								<input type="text" id="prompt-input" value="${defaultValue}" class="w-full rounded-2xl border border-black/5 bg-black/[0.03] px-4 py-3 outline-none focus:border-[var(--primary)] dark:border-white/5 dark:bg-white/5" />
							</div>
							<div class="flex gap-4">
								<button id="prompt-cancel" class="flex-1 rounded-2xl bg-black/5 py-4 text-sm font-bold text-black/40 transition-colors hover:bg-black/10 dark:bg-white/5 dark:text-white/40 dark:hover:bg-white/10">取消</button>
								<button id="prompt-ok" class="flex-1 rounded-2xl bg-[var(--primary)] py-4 text-sm font-bold text-white shadow-lg shadow-[var(--primary)]/20 transition-transform active:scale-95">确定</button>
							</div>
						</div>
					`;
					document.body.appendChild(overlay);
					const input = overlay.querySelector('#prompt-input');
					input.focus();
					input.select();
					
					requestAnimationFrame(() => {
						overlay.classList.remove('opacity-0');
						overlay.firstElementChild.classList.remove('scale-95');
					});

					const cleanup = (value) => {
						overlay.classList.add('opacity-0');
						overlay.firstElementChild.classList.add('scale-95');
						setTimeout(() => {
							overlay.remove();
							resolve(value);
						}, 300);
					};

					overlay.querySelector('#prompt-ok').onclick = () => cleanup(input.value);
					overlay.querySelector('#prompt-cancel').onclick = () => cleanup(null);
					input.onkeydown = (e) => {
						if (e.key === 'Enter') cleanup(input.value);
						if (e.key === 'Escape') cleanup(null);
					};
				});
			};

			window.adminIsDirty = false;

			document.addEventListener('click', async (e) => {
				const a = e.target.closest('a');
				if (a && window.adminIsDirty && a.hostname === window.location.hostname && !a.hasAttribute('data-no-intercept')) {
					e.preventDefault();
					const confirmed = await window.showAdminConfirm('你所做的更改可能未保存，确定要离开吗？');
					if (confirmed) {
						window.adminIsDirty = false;
						window.location.href = a.href;
					}
				}
			}, true);

			// Initial Toasts from Server
			if (success) window.showAdminToast(success, 'success');
			if (error) window.showAdminToast(error, 'error');
		</script>
		<script>
			import "@/components/GitHubCard.client";
		</script>
	</body>
</html>

<style is:global define:vars={{ adminHue: String(configHue) }}>
	:root {
		--hue: var(--adminHue);
		--radius-large: 1.25rem;
		--content-delay: 150ms;
		--primary: oklch(0.65 0.16 var(--hue));
		--page-bg: oklch(0.98 0.005 var(--hue));
		--card-bg: white;
		--btn-content: oklch(0.55 0.12 var(--hue));
		--btn-regular-bg: oklch(0.95 0.025 var(--hue));
		--btn-regular-bg-hover: oklch(0.92 0.04 var(--hue));
		--btn-regular-bg-active: oklch(0.88 0.06 var(--hue));
		--btn-plain-bg-hover: oklch(0.96 0.015 var(--hue));
		--btn-plain-bg-active: oklch(0.94 0.02 var(--hue));
		--line-divider: rgba(0, 0, 0, 0.06);
		--line-color: rgba(0, 0, 0, 0.08);
		--selection-bg: oklch(0.92 0.06 var(--hue));
		--float-panel-bg: white;
		--license-block-bg: rgba(0, 0, 0, 0.03);
		--admonitions-color-tip: oklch(0.7 0.14 180);
		--admonitions-color-note: oklch(0.7 0.14 250);
		--admonitions-color-important: oklch(0.7 0.14 310);
		--admonitions-color-warning: oklch(0.7 0.14 60);
		--admonitions-color-caution: oklch(0.6 0.2 25);
	}

	:root.dark {
		--primary: oklch(0.75 0.14 var(--hue));
		--page-bg: oklch(0.14 0.012 var(--hue));
		--card-bg: oklch(0.18 0.015 var(--hue));
		--btn-content: oklch(0.85 0.08 var(--hue));
		--btn-regular-bg: oklch(0.24 0.025 var(--hue));
		--btn-regular-bg-hover: oklch(0.28 0.03 var(--hue));
		--btn-regular-bg-active: oklch(0.32 0.035 var(--hue));
		--btn-plain-bg-hover: oklch(0.22 0.02 var(--hue));
		--btn-plain-bg-active: oklch(0.26 0.025 var(--hue));
		--line-divider: rgba(255, 255, 255, 0.06);
		--line-color: rgba(255, 255, 255, 0.08);
		--selection-bg: oklch(0.35 0.08 var(--hue));
		--float-panel-bg: oklch(0.2 0.02 var(--hue));
		--license-block-bg: oklch(0.17 0.015 var(--hue));
		--admonitions-color-tip: oklch(0.75 0.14 180);
		--admonitions-color-note: oklch(0.75 0.14 250);
		--admonitions-color-important: oklch(0.75 0.14 310);
		--admonitions-color-warning: oklch(0.75 0.14 60);
		--admonitions-color-caution: oklch(0.65 0.2 25);
	}

	body[data-admin] {
		font-family: "Roboto", system-ui, sans-serif;
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}

	/* Card Base Styling */
	body[data-admin] .card-base,
	body[data-admin] [data-admin-card] {
		border: 1px solid var(--line-color);
		background: color-mix(in oklab, var(--card-bg) 95%, transparent);
		box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.04);
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		border-radius: var(--radius-large);
	}

	.dark body[data-admin] .card-base,
	.dark body[data-admin] [data-admin-card] {
		box-shadow: 0 10px 40px -15px rgba(0, 0, 0, 0.4);
	}

	/* Input Styling Consistency */
	body[data-admin] input:not([type="checkbox"]):not([type="radio"]):not([type="range"]),
	body[data-admin] textarea,
	body[data-admin] select {
		appearance: none;
		background: color-mix(in oklab, var(--card-bg) 80%, transparent);
		border: 1.5px solid var(--line-color);
		border-radius: 1rem;
		padding: 0.8rem 1.1rem;
		font-size: 0.95rem;
		color: inherit;
		outline: none;
		transition: all 0.2s ease;
		width: 100%;
		max-width: 100%;
	}

	body[data-admin] input:focus,
	body[data-admin] textarea:focus,
	body[data-admin] select:focus {
		border-color: var(--primary);
		background: var(--card-bg);
		box-shadow: 0 0 0 4px color-mix(in oklch, var(--primary) 15%, transparent);
	}

	body[data-admin] .admin-label {
		display: block;
		margin-bottom: 0.6rem;
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		color: rgba(0, 0, 0, 0.6);
	}
	
	.dark body[data-admin] .admin-label {
		color: rgba(255, 255, 255, 0.6);
	}

	/* Button Styling Refinement */
	body[data-admin] [data-admin-plain-btn],
	body[data-admin] .btn-plain {
		background: var(--btn-plain-bg-hover);
		border: 1px solid var(--line-color);
		color: var(--btn-content);
	}

	body[data-admin] [data-admin-regular-btn],
	body[data-admin] .btn-regular {
		background: var(--primary);
		color: white;
		border: none;
		box-shadow: 0 4px 12px -2px color-mix(in oklch, var(--primary) 30%, transparent);
	}
	
	body[data-admin] [data-admin-regular-btn]:hover,
	body[data-admin] .btn-regular:hover {
		filter: brightness(1.05);
		transform: translateY(-1px);
	}
	
	body[data-admin] [data-admin-regular-btn]:active,
	body[data-admin] .btn-regular:active {
		transform: translateY(0);
	}

	/* Scrollbar refinement */
	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	::-webkit-scrollbar-track {
		background: transparent;
